# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/studexa

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# Ticketing — resolution emails (Gmail SMTP)
# When an admin marks a ticket as resolved, a notification is sent to the user.
# Leave unset to disable sending (tickets still work; only email is skipped).
EMAIL_USER=your-gmail@gmail.com 
EMAIL_PASS=your-app-password

# Optional
# GROQ_API_KEY=
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# OTP_EXPIRY_MINUTES=10
# AI_DAILY_LIMIT=100
